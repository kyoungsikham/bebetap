<?xml version="1.0" encoding="utf-8"?>
<!--
  2x2 컴팩트 위젯 피커 미리보기.
  헤더(수유 경과 + 오늘 총량) + 버튼 2개 구조를 모사.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 카드 배경 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF"/>
            <corners android:radius="22dp"/>
        </shape>
    </item>

    <!-- BebeTap 라벨 -->
    <item
        android:left="12dp"
        android:top="10dp"
        android:right="70dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF8A8A9A"/>
            <corners android:radius="2dp"/>
            <size android:height="5dp"/>
        </shape>
    </item>

    <!-- 헤더 텍스트 (굵게) -->
    <item
        android:left="12dp"
        android:top="20dp"
        android:right="20dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF1C1C1E"/>
            <corners android:radius="3dp"/>
            <size android:height="9dp"/>
        </shape>
    </item>

    <!-- 오늘 총량 텍스트 -->
    <item
        android:left="12dp"
        android:top="34dp"
        android:right="50dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF8A8A9A"/>
            <corners android:radius="2dp"/>
            <size android:height="7dp"/>
        </shape>
    </item>

    <!-- 버튼 1 — 분유 (파란 파스텔) -->
    <item
        android:left="12dp"
        android:top="60dp"
        android:right="0dp"
        android:bottom="12dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFE3EAFF"/>
            <corners android:radius="18dp"/>
            <size android:width="50dp" android:height="34dp"/>
        </shape>
    </item>

    <!-- 버튼 2 — 모유 (보라 파스텔) -->
    <item
        android:left="68dp"
        android:top="60dp"
        android:right="12dp"
        android:bottom="12dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFE8E3FB"/>
            <corners android:radius="18dp"/>
            <size android:width="50dp" android:height="34dp"/>
        </shape>
    </item>

</layer-list>
